# Application
APP_ENV=development
APP_NAME=FreightFlex API

# Database (required)
DATABASE_URL=mysql+pymysql://freightflex_user:freightflex_pass@localhost:3306/freightflex?charset=utf8mb4

# Redis (optional — leave blank to use in-memory fallback for refresh tokens)
# REDIS_URL=redis://localhost:6379/0

# JWT RS256 keys (required)
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=30

# Azure Blob Storage (optional — document/invoice uploads skipped if blank)
# AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
# AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
# AZURE_CONTAINER_DOCS=freightflex-docs
# AZURE_CONTAINER_INVOICES=freightflex-invoices

# Google Maps (optional — haversine distance used as fallback)
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Razorpay (optional — payment endpoints inactive if blank)
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=your-razorpay-secret
# RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# SendGrid (optional — emails logged to console if blank)
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_FROM_EMAIL=noreply@freightflex.io

# Firebase FCM (optional — push notifications skipped if blank)
# FCM_SERVER_KEY=your-fcm-server-key
# FIREBASE_CREDENTIALS_JSON=/path/to/firebase-service-account.json

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# Celery (optional — background tasks run inline if blank)
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2
