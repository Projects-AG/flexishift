default_platform(:ios)

IOS_PROJECT = "mobile.xcodeproj"
IOS_WORKSPACE = "mobile.xcworkspace"
IOS_SCHEME = "mobile"
IOS_TARGET = "mobile"
TEAM_ID = "N5UWYZH7Y8"

platform :ios do
  private_lane :load_asc_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("APP_STORE_CONNECT_API_KEY_PATH"),
      duration: 1200,
      in_house: false
    )
  end

  private_lane :configure_code_signing do |options|
    api_key = options[:api_key]
    readonly = options.fetch(:readonly, true)

    match(
      type: "appstore",
      readonly: readonly,
      api_key: api_key
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: IOS_PROJECT,
      team_id: TEAM_ID,
      targets: [IOS_TARGET],
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore #{CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)}"
    )
  end

  desc "Install App Store signing certificates and provisioning profiles (read-only)"
  lane :certs do
    api_key = load_asc_api_key
    configure_code_signing(api_key: api_key, readonly: true)
  end

  desc "Generate and push new App Store certificates (one-time / occasional setup)"
  lane :bootstrap_certs do
    api_key = load_asc_api_key
    configure_code_signing(api_key: api_key, readonly: false)
  end

  desc "Build the app and upload to TestFlight"
  lane :beta do
    api_key = load_asc_api_key
    configure_code_signing(api_key: api_key, readonly: true)

    cocoapods(
      podfile: "./Podfile",
      try_repo_update_on_mismatch: true
    )

    build_app(
      workspace: IOS_WORKSPACE,
      scheme: IOS_SCHEME,
      export_method: "app-store",
      clean: true,
      output_directory: "./build"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
